generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model InstructionOrder {
  id           String       @id @default(cuid())
  tradeDate    String
  symbol       String
  symbolName   String?
  side         OrderSide
  limitPrice   Decimal
  lots         Int
  shares       Int
  validity     OrderValidity
  status       OrderStatus   @default(confirmed)
  statusReason String?
  triggeredAt  DateTime?
  filledAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  events       OrderEvent[]
  trades       ExecutionTrade[]

  @@index([tradeDate, status])
  @@index([symbol, tradeDate])
}

model OrderEvent {
  id           String           @id @default(cuid())
  orderId      String
  eventType    OrderStatus
  eventTime    DateTime         @default(now())
  message      String
  metadataJson String?
  order        InstructionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, eventTime])
}

model ExecutionTrade {
  id            String           @id @default(cuid())
  orderId       String
  symbol        String
  side          OrderSide
  orderPrice    Decimal
  fillPrice     Decimal
  costBasisAmount Decimal        @default(0)
  realizedPnl   Decimal          @default(0)
  lots          Int
  shares        Int
  fillTime      DateTime
  cashAfter     Decimal
  positionAfter Int
  order         InstructionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([symbol, fillTime])
}

model PositionLot {
  id             String      @id @default(cuid())
  symbol         String
  symbolName     String?
  openedOrderId  String?
  openedTradeId  String?
  openedDate     String
  openedAt       DateTime
  costPrice      Decimal
  originalShares Int
  remainingShares Int
  sellableShares Int
  status         PositionStatus @default(OPEN)
  closedAt       DateTime?

  @@index([symbol, status])
}

model CashLedger {
  id            String         @id @default(cuid())
  entryTime     DateTime       @default(now())
  entryType     CashEntryType
  amount        Decimal
  balanceAfter  Decimal
  referenceId   String?
  referenceType String?

  @@index([entryTime])
}

model DailyPnl {
  id                  String   @id @default(cuid())
  tradeDate           String   @unique
  totalAssets         Decimal
  availableCash       Decimal
  positionMarketValue Decimal
  dailyPnl            Decimal
  dailyReturn         Decimal
  cumulativePnl       Decimal
  buyAmount           Decimal
  sellAmount          Decimal
  tradeCount          Int
  details             DailyPnlDetail[]

  @@index([tradeDate])
}

model DailyPnlDetail {
  id             String   @id @default(cuid())
  dailyPnlId     String
  tradeDate      String
  symbol         String
  symbolName     String?
  openingShares  Int      @default(0)
  closingShares  Int
  buyShares      Int      @default(0)
  sellShares     Int      @default(0)
  buyPrice       Decimal  @default(0)
  sellPrice      Decimal  @default(0)
  openPrice      Decimal  @default(0)
  closePrice     Decimal
  realizedPnl    Decimal  @default(0)
  unrealizedPnl  Decimal  @default(0)
  dailyPnl       Decimal
  dailyReturn    Decimal
  daily          DailyPnl @relation(fields: [dailyPnlId], references: [id], onDelete: Cascade)

  @@index([tradeDate, symbol])
}

model ImportBatch {
  id              String            @id @default(cuid())
  targetTradeDate String
  sourceType      ImportSourceType
  fileName        String?
  mode            ImportMode
  status          ImportBatchStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  items           ImportBatchItem[]

  @@index([targetTradeDate, status])
}

model ImportBatchItem {
  id                String           @id @default(cuid())
  batchId           String
  rowNumber         Int
  symbol            String
  side              OrderSide
  limitPrice        Decimal
  lots              Int
  validity          OrderValidity
  validationStatus  ValidationStatus
  validationMessage String?
  batch             ImportBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, rowNumber])
}

enum OrderSide {
  BUY
  SELL
}

enum OrderValidity {
  DAY
  GTC
}

enum OrderStatus {
  confirmed
  pending
  triggered
  filled
  expired
  rejected
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum CashEntryType {
  INITIAL
  BUY
  SELL
  MANUAL_ADJUSTMENT
}

enum ImportSourceType {
  MANUAL
  XLSX
  CSV
}

enum ImportMode {
  DRAFT
  OVERWRITE
  APPEND
}

enum ImportBatchStatus {
  PENDING
  VALIDATED
  COMMITTED
  FAILED
}

enum ValidationStatus {
  VALID
  WARNING
  ERROR
}
